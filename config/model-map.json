{
  "backends": {
    "anthropic": {
      "kind": "anthropic",
      "url": "https://api.anthropic.com",
      "auth_env": "ANTHROPIC_API_KEY"
    },
    "openrouter": {
      "kind": "anthropic",
      "url": "https://openrouter.ai/api/v1",
      "auth_env": "OPENROUTER_API_KEY"
    },
    "ollama_local": {
      "kind": "ollama",
      "url": "http://localhost:11434"
    },
    "ollama_cloud": {
      "kind": "ollama",
      "url": "http://localhost:11434"
    }
  },
  "model_routes": {
    "claude-sonnet-4-6": "anthropic",
    "claude-opus-4-6": "anthropic",
    "re:^claude-.*$": "anthropic",
    "qwen3-coder:30b": "ollama_local",
    "gemma4:26b": "ollama_local",
    "qwen3-coder:480b-cloud": "ollama_cloud",
    "deepseek/deepseek-v3": "openrouter",
    "qwen3-coder-next:cloud": "ollama_cloud",
    "qwen3.5:35b-a3b-coding-nvfp4": "ollama_local"
  },
  "routes": {
    "default": "medium-model",
    "medium-model": "qwen3.5:35b-a3b-coding-nvfp4",
    "high-model": "qwen3-coder-next:cloud",
    "background": "qwen3.5:35b-a3b-coding-nvfp4",
    "cloud_background": "qwen3-coder-next:cloud",
    "think": "claude-sonnet-4-6",
    "longContext": "claude-sonnet-4-6",
    "claude-sonnet-4-6": "qwen3.5:35b-a3b-coding-nvfp4"
  },
  "llm_capabilities": {
    "default": {
      "model": "medium-model"
    },
    "review_plan": {
      "model": "high-model"
    },
    "review_code": {
      "model": "high-model"
    }
  },
  "ollama_defaults": {
    "num_ctx": 65536
  }
}
