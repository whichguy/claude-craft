def calculate_stats(numbers):
    if not numbers:
        print("Average: N/A (empty list)")
        return None

    total = 0
    for n in numbers:
        total += n
        
    average = total / len(numbers)
    print(f"Average: {average}")
    return average

if __name__ == "__main__":
    try:
        data = [10, 20, 30]
        calculate_stats(data)
        calculate_stats([])
    except Exception as e:
        print(f"Unexpected error: {e}")
