#!/bin/bash
# claude-router — route Claude Code to any model provider
# Provider lookup: 1) model-map.json providers  2) local Ollama tag match  3) assume Ollama (name passthrough)
# Supports: Ollama (local), OpenRouter, LiteLLM, Bedrock, Vertex, any custom endpoint.
# All args pass through to claude unchanged.
#
# Usage: claude-router --model gemma4:26b          — Ollama (auto-detected)
#        claude-router --model bedrock-opus        — Bedrock (from model-map.json)
#        claude-router --model opus                — Ollama if not in model-map (name passed through)
#        claude-router --route background          — named route from model-map.json .routes
#        claude-router --route background -p .     — route + pass -p to claude
#        claude-router --list                       — show all available models and routes
#        claude-router                              — show help + available models
set -eo pipefail

CONFIG="$HOME/.claude/model-map.json"
OLLAMA_URL="${OLLAMA_BASE_URL:-http://localhost:11434}"

# Ensure target Ollama model is loaded on the given host; warm it in a subprocess if not.
# Three-state probe: unreachable → skip with hint; loaded → skip; cached-not-loaded → warm.
# Avoids silent model pulls: if the model isn't cached on the target host, prints a pull
# hint instead of firing `ollama run` (which would trigger a multi-GB download in background).
# Non-fatal — failures do not block routing.
ensure_ollama_running() {
  local model="$1"
  local host="$2"
  command -v ollama >/dev/null 2>&1 || return 0   # no CLI → skip silently

  # 3s timeout prevents unreachable-host hangs (~75s default TCP). Fall back to direct
  # invocation if no timeout CLI is available (bare macOS) — the `ollama` CLI itself
  # still has its own internal timeout, which is a bit longer but bounded.
  local -a timeout_cmd=()
  if command -v timeout >/dev/null 2>&1; then
    timeout_cmd=(timeout 3)
  elif command -v gtimeout >/dev/null 2>&1; then
    timeout_cmd=(gtimeout 3)
  fi

  # --- Probe 1: is the server reachable AND is the model already loaded? ---
  # Capture stdout and exit code separately so we can distinguish "unreachable"
  # (exit non-zero) from "up but model not loaded" (exit 0, model absent from output).
  local ps_output
  if ! ps_output=$(OLLAMA_HOST="$host" "${timeout_cmd[@]}" ollama ps 2>/dev/null); then
    echo "claude-router: cannot reach Ollama on $host — is 'ollama serve' running there? Skipping warm-up." >&2
    return 0
  fi

  # grep -Fxq: Fixed-string, whole-line, quiet — handles model names with regex chars
  if echo "$ps_output" | awk 'NR>1 {print $1}' | grep -Fxq "$model"; then
    return 0   # already loaded on that host
  fi

  # --- Probe 2: is the model cached on that host? ---
  # Server is up but model isn't loaded. Before firing `ollama run` (which would
  # transparently trigger `ollama pull` for an uncached model — a multi-GB silent
  # download), verify the model is actually cached and give the user a pull hint if not.
  local list_output
  list_output=$(OLLAMA_HOST="$host" "${timeout_cmd[@]}" ollama list 2>/dev/null) || {
    # ps worked but list didn't — unexpected; bail safely without warming
    return 0
  }

  if ! echo "$list_output" | awk 'NR>1 {print $1}' | grep -Fxq "$model"; then
    echo "claude-router: '$model' not cached on $host — run 'OLLAMA_HOST=$host ollama pull $model' first to avoid a slow first request" >&2
    return 0
  fi

  # --- Cached + not loaded + reachable → fire background warm-up ---
  echo "claude-router: warming '$model' on $host (background)..." >&2
  # `ollama run <model> ""` loads the model and exits quickly on empty prompt.
  # Fully detached: stdin from /dev/null, outputs to /dev/null, backgrounded + disowned.
  OLLAMA_HOST="$host" nohup ollama run "$model" "--options" "num_ctx=65536" </dev/null >/dev/null 2>&1 &
  disown 2>/dev/null || true
}

[[ -f "$CONFIG" ]] && chmod 600 "$CONFIG" 2>/dev/null

# --- Show available models from all sources ---
show_models() {
  # Configured routes
  if [[ -f "$CONFIG" ]] && jq -e '.routes | length > 0' "$CONFIG" >/dev/null 2>&1; then
    echo "Configured routes (model-map.json):"
    jq -r '.routes | to_entries[] | "  \(.key)  →  \(.value)"' "$CONFIG" 2>/dev/null
    echo ""
  fi

  # Configured providers
  if [[ -f "$CONFIG" ]] && jq -e '.providers | length > 0' "$CONFIG" >/dev/null 2>&1; then
    echo "Configured providers (model-map.json):"
    jq -r '.providers | to_entries[] | "  \(.key)  →  \(.value.base_url // (.value.env | to_entries[0] | "\(.key)=\(.value)") // "custom")"' "$CONFIG" 2>/dev/null
    echo ""
  fi

  # Local Ollama
  local ollama_models
  ollama_models=$(curl -sf "$OLLAMA_URL/api/tags" 2>/dev/null | jq -r '.models[].name' 2>/dev/null) || true
  if [[ -n "$ollama_models" ]]; then
    echo "Local Ollama ($OLLAMA_URL):"
    echo "$ollama_models" | while read -r m; do
      if [[ -f "$CONFIG" ]] && jq -e --arg m "$m" '.providers[$m]' "$CONFIG" >/dev/null 2>&1; then
        echo "  $m  (custom config)"
      else
        echo "  $m"
      fi
    done
    echo ""
  fi

  echo "Any other model name is assumed to be available from local Ollama ($OLLAMA_URL)."
}

# --- Help / no args ---
if [[ $# -eq 0 ]]; then
  echo "Usage: claude-router --model <model> [claude args...]"
  echo "       claude-router --route <name>  [claude args...]"
  echo "       claude-router --list"
  echo ""
  echo "Routes Claude Code to the right provider for any model."
  echo "  --route <name>   use a named route from model-map.json .routes block"
  echo "  --model <model>  explicit model (wins over --route if both given)"
  echo "Priority: configured providers → Ollama (tag match) → Ollama (assumed for unknown names)"
  echo ""
  show_models
  exit 1
fi

if [[ "$1" == "--list" ]]; then
  show_models
  exit 0
fi

# --- Extract --route and --model from args (peek — don't consume) ---
MODEL=""
ROUTE=""
prev=""
for arg in "$@"; do
  if [[ "$prev" == "--model" ]]; then
    MODEL="$arg"
  elif [[ "$prev" == "--route" ]]; then
    ROUTE="$arg"
  fi
  if [[ "$arg" == --model=* ]]; then
    MODEL="${arg#--model=}"
  fi
  if [[ "$arg" == --route=* ]]; then
    ROUTE="${arg#--route=}"
  fi
  prev="$arg"
done

# --- Resolve route → model (only when --model not explicitly set) ---
if [[ -n "$ROUTE" && -z "$MODEL" ]]; then
  if [[ ! -f "$CONFIG" ]] || ! jq -e 'has("routes")' "$CONFIG" >/dev/null 2>&1; then
    echo "claude-router: --route '$ROUTE' requires a 'routes' block in $CONFIG — run '/model-map route $ROUTE <model>' to add one" >&2
    exit 1
  fi
  MODEL=$(jq -r --arg k "$ROUTE" '.routes[$k] | select(type == "string" and length > 0) // empty' "$CONFIG" 2>/dev/null)
  if [[ -z "$MODEL" ]]; then
    available=$(jq -r '.routes | keys | join(", ")' "$CONFIG" 2>/dev/null || echo "(none)")
    echo "claude-router: route '$ROUTE' not found or invalid in $CONFIG; available routes: $available" >&2
    exit 1
  fi
fi

if [[ -z "$MODEL" ]]; then
  echo "Error: --model <model> or --route <name> is required"
  echo "Usage: claude-router --model <model> [claude args...]"
  echo "       claude-router --route <name>  [claude args...]"
  exit 1
fi

# --- Provider lookup chain ---
PROVIDER=""
if [[ -f "$CONFIG" ]]; then
  PROVIDER=$(jq -r --arg m "$MODEL" '.providers[$m] // empty' "$CONFIG" 2>/dev/null)
fi

if [[ -n "$PROVIDER" && "$PROVIDER" != "null" ]]; then
  # 1) Explicit provider config from model-map.json (any provider: Ollama, OpenRouter, custom)
  BASE_URL=$(echo "$PROVIDER" | jq -r '.base_url // empty')
  # Expand $OLLAMA_URL / $OLLAMA_BASE_URL placeholders. Literal URLs pass through unchanged,
  # so per-model overrides (e.g., http://localhost:11435 for cloud) just work.
  BASE_URL="${BASE_URL/\$OLLAMA_URL/$OLLAMA_URL}"
  BASE_URL="${BASE_URL/\$OLLAMA_BASE_URL/$OLLAMA_URL}"
  AUTH_TOKEN=$(echo "$PROVIDER" | jq -r '.auth_token // empty')
  CONFIG_DIR=$(echo "$PROVIDER" | jq -r '.config_dir // empty')
  DISABLE_TRAFFIC=$(echo "$PROVIDER" | jq -r '.disable_nonessential_traffic // false')

  [[ -n "$BASE_URL" ]] && export ANTHROPIC_BASE_URL="$BASE_URL"
  [[ -n "$AUTH_TOKEN" ]] && export ANTHROPIC_AUTH_TOKEN="$AUTH_TOKEN"
  if echo "$PROVIDER" | jq -e 'has("api_key")' >/dev/null 2>&1; then
    ANTHROPIC_API_KEY="$(echo "$PROVIDER" | jq -r '.api_key')"
    export ANTHROPIC_API_KEY
  fi
  [[ -n "$CONFIG_DIR" ]] && export CLAUDE_CONFIG_DIR="${CONFIG_DIR//\$HOME/$HOME}"
  [[ "$DISABLE_TRAFFIC" == "true" ]] && export CLAUDE_CODE_DISABLE_NONESSENTIAL_TRAFFIC=1

  # Generic env block — supports Bedrock, Vertex, or any custom env vars
  ENV_KEYS=$(echo "$PROVIDER" | jq -r '.env // {} | keys[]' 2>/dev/null)
  if [[ -n "$ENV_KEYS" ]]; then
    while IFS= read -r key; do
      val=$(echo "$PROVIDER" | jq -r --arg k "$key" '.env[$k]' 2>/dev/null)
      export -- "$key=$val"
    done <<< "$ENV_KEYS"
  fi

  if [[ "$AUTH_TOKEN" == "ollama" ]]; then
    ensure_ollama_running "$MODEL" "$BASE_URL"
  fi

elif curl -sf "$OLLAMA_URL/api/tags" 2>/dev/null | jq -e --arg m "$MODEL" '.models[] | select(.name == $m)' >/dev/null 2>&1; then
  # 2) Listed in local Ollama /api/tags — apply defaults
  export ANTHROPIC_BASE_URL="$OLLAMA_URL"
  export ANTHROPIC_AUTH_TOKEN="ollama"
  export ANTHROPIC_API_KEY=""
  export CLAUDE_CONFIG_DIR="$HOME/.claude-ollama"
  export CLAUDE_CODE_DISABLE_NONESSENTIAL_TRAFFIC=1
  ensure_ollama_running "$MODEL" "$OLLAMA_URL"
else
  # 3) Unknown to model-map and not in tag list — still assume Ollama; pass model name through
  echo "claude-router: '$MODEL' not in model-map providers or local Ollama tags — assuming Ollama at $OLLAMA_URL" >&2
  export ANTHROPIC_BASE_URL="$OLLAMA_URL"
  export ANTHROPIC_AUTH_TOKEN="ollama"
  export ANTHROPIC_API_KEY=""
  export CLAUDE_CONFIG_DIR="$HOME/.claude-ollama"
  export CLAUDE_CODE_DISABLE_NONESSENTIAL_TRAFFIC=1
  ensure_ollama_running "$MODEL" "$OLLAMA_URL"
fi

# Build final argv: if --route was used, strip it (and any existing --model) then inject
# --model with the resolved value. Use explicit array rebuild to preserve multi-word -p prompts.
if [[ -n "$ROUTE" ]]; then
  new_args=()
  skip_next=0
  for arg in "$@"; do
    if [[ "$skip_next" == 1 ]]; then
      skip_next=0
      continue
    fi
    case "$arg" in
      --route|--model) skip_next=1 ;;    # drop "--route <name>" and "--model <name>" pairs
      --route=*|--model=*) ;;            # drop "--route=<name>" and "--model=<name>"
      *)           new_args+=("$arg") ;;
    esac
  done
  new_args+=(--model "$MODEL")
  exec claude "${new_args[@]}"
fi

# Pass ALL original args through to claude unchanged
exec claude "$@"
