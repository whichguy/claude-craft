#!/usr/bin/env node
'use strict';

const http = require('http');
const https = require('https');
const fs = require('fs');
const path = require('path');
const crypto = require('crypto');
const { spawn, spawnSync } = require('child_process');

// ── Config resolution ──────────────────────────────────────────────────

function canonicalizeDir(dir) {
  if (!dir || typeof dir !== 'string' || !dir.startsWith('/') || !fs.statSync(dir, { throwIfNoEntry: false })?.isDirectory()) return null;
  try { return fs.realpathSync(dir); } catch { return null; }
}

function canonicalizeFile(file) {
  if (!file || typeof file !== 'string' || !file.startsWith('/') || !fs.existsSync(file)) return null;
  const dir = canonicalizeDir(path.dirname(file));
  return dir ? path.join(dir, path.basename(file)) : null;
}

function findParentModelMap(dir) {
  const real = canonicalizeDir(dir);
  if (!real) return null;
  let cur = real;
  while (true) {
    const candidate = path.join(cur, '.claude', 'model-map.json');
    const realFile = canonicalizeFile(candidate);
    if (realFile) return realFile;
    if (cur === '/') break;
    cur = path.dirname(cur);
  }
  return null;
}

function resolveConfigPath() {
  const override = process.env.CLAUDE_MODEL_MAP_PATH;
  if (override) {
    const real = canonicalizeFile(override);
    if (real) return { path: real, source: 'override' };
  }

  const launchCwd = process.env.CLAUDE_MODEL_MAP_LAUNCH_CWD || process.cwd();

  // Check project dir env var
  const projectDir = process.env.CLAUDE_PROJECT_DIR;
  if (projectDir) {
    const real = canonicalizeFile(path.join(projectDir, '.claude', 'model-map.json'));
    if (real) return { path: real, source: 'project' };
  }

  // Walk upward from launch CWD
  const walked = findParentModelMap(launchCwd);
  if (walked) {
    // Skip if it's the same as the profile config
    const profileReal = canonicalizeFile(path.join(process.env.HOME || '', '.claude', 'model-map.json'));
    if (walked !== profileReal) return { path: walked, source: 'project' };
  }

  // Fallback to profile config
  const profileReal = canonicalizeFile(path.join(process.env.HOME || '', '.claude', 'model-map.json'));
  if (profileReal) return { path: profileReal, source: 'profile' };

  return null;
}

// ── Config loading & reload ────────────────────────────────────────────

const INITIAL_PORT = Number(process.env.CLAUDE_PROXY_PORT) || 11000;
const SKIP_WARMUP = process.env.CLAUDE_PROXY_SKIP_OLLAMA_WARMUP === '1';
const ANNOTATE_MODEL = process.env.CLAUDE_PROXY_ANNOTATE_MODEL === '1';
const OLLAMA_LEGACY = process.env.CLAUDE_PROXY_OLLAMA_LEGACY_TRANSLATE === '1';
const DEBUG = Number(process.env.CLAUDE_ROUTER_DEBUG || '0');
const DEFAULT_OLLAMA_URL = process.env.OLLAMA_BASE_URL || 'http://localhost:11434';

let CONFIG;
let CONFIG_PATH;
let CONFIG_SOURCE;

function loadConfig() {
  const resolved = resolveConfigPath();
  if (!resolved) {
    console.error('claude-proxy: no model-map.json found');
    process.exit(1);
  }
  CONFIG_PATH = resolved.path;
  CONFIG_SOURCE = resolved.source;
  try {
    CONFIG = JSON.parse(fs.readFileSync(CONFIG_PATH, 'utf8'));
  } catch (e) {
    console.error(`claude-proxy: failed to load ${CONFIG_PATH}: ${e.message}`);
    process.exit(1);
  }
  // Validate no cycles in routes
  validateRouteGraph();
  // Validate with external validator if available
  validateWithNode();
}

function validateRouteGraph() {
  const routes = CONFIG.routes || {};
  const seen = new Set();
  for (const start of Object.keys(routes)) {
    seen.clear();
    let cur = start;
    let steps = 0;
    while (routes[cur] !== undefined) {
      if (seen.has(cur)) {
        console.error(`claude-proxy: route cycle detected involving '${cur}' in ${CONFIG_PATH}`);
        process.exit(1);
      }
      seen.add(cur);
      cur = routes[cur];
      steps++;
      if (steps > 256) {
        console.error(`claude-proxy: route resolution limit hit starting at '${start}'`);
        process.exit(1);
      }
    }
  }
}

function validateWithNode() {
  const validator = path.join(path.dirname(process.argv[1] || ''), 'model-map-validate.js');
  if (!fs.existsSync(validator)) return;
  try {
    const result = spawnSync(process.execPath, [validator, CONFIG_PATH], { encoding: 'utf8', timeout: 5000 });
    if (result.status !== 0) {
      console.error(`claude-proxy: invalid model-map config: ${CONFIG_PATH}`);
      process.exit(1);
    }
  } catch { /* validator not critical */ }
}

loadConfig();

// Watch for config changes
let configWatcher = null;
let reloadTimer = null;
try {
  const watchDir = path.dirname(CONFIG_PATH);
  configWatcher = fs.watch(watchDir, (eventType, filename) => {
    if (filename === path.basename(CONFIG_PATH)) {
      if (reloadTimer) clearTimeout(reloadTimer);
      reloadTimer = setTimeout(() => {
        try {
          const newConfig = JSON.parse(fs.readFileSync(CONFIG_PATH, 'utf8'));
          CONFIG = newConfig;
          validateRouteGraph();
          console.error(`claude-proxy: reloaded config from ${CONFIG_PATH}`);
        } catch (e) {
          console.error(`claude-proxy: config reload failed, keeping old config: ${e.message}`);
        }
      }, 50);
    }
  });
  configWatcher.on('error', () => {});
} catch { /* fs.watch not available on all platforms */ }

// ── Route resolution ───────────────────────────────────────────────────

function resolveRouteModel(model) {
  const routes = CONFIG.routes || {};
  const seen = new Set();
  let cur = model;
  let steps = 0;
  while (routes[cur] !== undefined) {
    if (seen.has(cur)) return cur; // cycle — return last resolved
    seen.add(cur);
    cur = routes[cur];
    steps++;
    if (steps >= 32) return cur;
  }
  return cur;
}

function looksLikePatternKey(key) {
  return key.startsWith('re:') || /[*?\[]/.test(key);
}

function matchPattern(key, model) {
  if (key.startsWith('re:')) {
    try { return new RegExp(key.slice(3)).test(model); } catch { return false; }
  }
  // Glob-style matching
  const regex = key.replace(/[.+^${}()|]/g, '\\$&').replace(/\*/g, '.*').replace(/\?/g, '.');
  try { return new RegExp(`^${regex}$`).test(model); } catch { return false; }
}

function lookupPatternValue(section, model) {
  const obj = CONFIG[section] || {};
  for (const [key, value] of Object.entries(obj)) {
    if (!looksLikePatternKey(key)) continue;
    if (matchPattern(key, model)) return value;
  }
  return null;
}

// ── Request stats tracking ─────────────────────────────────────────────

const stats = {
  requestsTotal: 0,
  byEndpoint: {},
  byBackendKind: {},
  byClientModel: {},
  byEffectiveModel: {},
  byStatus: {},
  currentInFlight: 0,
};

function recordStats(endpoint, backend, clientModel, effectiveModel, statusCode) {
  stats.requestsTotal++;
  stats.byEndpoint[endpoint] = (stats.byEndpoint[endpoint] || 0) + 1;
  if (backend) stats.byBackendKind[backend.kind || 'unknown'] = (stats.byBackendKind[backend.kind || 'unknown'] || 0) + 1;
  if (clientModel) stats.byClientModel[clientModel] = (stats.byClientModel[clientModel] || 0) + 1;
  if (effectiveModel) stats.byEffectiveModel[effectiveModel] = (stats.byEffectiveModel[effectiveModel] || 0) + 1;
  if (statusCode) stats.byStatus[String(statusCode)] = (stats.byStatus[String(statusCode)] || 0) + 1;
}

// ── Fallback strategies ───────────────────────────────────────────────

const VALID_FAILURE_CLASSES = new Set(['network', 'rate_limit', 'account_quota', 'context_limit']);
const cooldowns = new Map(); // model -> { untilMs, failureClass }

function classifyError(statusCode, headers) {
  if (statusCode === 429) return 'rate_limit';
  if (statusCode === 402 || statusCode === 403) return 'account_quota';
  if (statusCode === 413) return 'context_limit';
  if (statusCode >= 500) return 'network';
  return null;
}

function getCooldownMs(model, failureClass) {
  const strategies = CONFIG.fallback_strategies || {};
  const strategy = strategies[model];
  if (!strategy) return 0;
  const cooldown = (strategy.cooldown || {})[failureClass];
  if (!cooldown) return 0;
  if (cooldown.mode === 'none') return 0;
  if (cooldown.mode === 'fixed' || cooldown.mode === 'header_or_max') {
    return (cooldown.seconds || cooldown.max_seconds || 0) * 1000;
  }
  return 0;
}

function isCooledDown(model) {
  const entry = cooldowns.get(model);
  if (!entry) return false;
  if (Date.now() >= entry.untilMs) {
    cooldowns.delete(model);
    return false;
  }
  return true;
}

function setCooldown(model, failureClass, statusCode, headers) {
  const strategies = CONFIG.fallback_strategies || {};
  const strategy = strategies[model];
  if (!strategy) return;
  const cooldown = (strategy.cooldown || {})[failureClass];
  if (!cooldown) return;
  let ms = 0;
  if (cooldown.mode === 'header_or_max') {
    const retryAfter = headers?.['retry-after'];
    if (retryAfter) {
      ms = Number(retryAfter) * 1000;
    }
    ms = ms || (cooldown.max_seconds || 0) * 1000;
  } else if (cooldown.mode === 'fixed') {
    ms = (cooldown.seconds || 0) * 1000;
  }
  // mode === 'none' → no cooldown
  if (ms > 0) cooldowns.set(model, { untilMs: Date.now() + ms, failureClass });
}

function resolveFallbackModel(model, failureClass) {
  const strategies = CONFIG.fallback_strategies || {};
  const strategy = strategies[model];
  if (!strategy || !strategy.on) return null;
  const candidates = strategy.on[failureClass];
  if (!Array.isArray(candidates) || candidates.length === 0) return null;
  for (const candidate of candidates) {
    const resolved = resolveRouteModel(candidate);
    if (!isCooledDown(resolved)) return resolved;
  }
  return null;
}

// ── Backend resolution ─────────────────────────────────────────────────

function ollamaHostEnvFromUrl(urlStr) {
  try {
    const u = new URL(urlStr);
    return `${u.protocol}//${u.host}`;
  } catch {
    return 'http://127.0.0.1:11434';
  }
}

function ensureOllamaModelLoaded(model, backendUrl) {
  if (SKIP_WARMUP) return;
  const ollamaHost = ollamaHostEnvFromUrl(backendUrl);
  const run = args =>
    spawnSync('ollama', args, {
      env: { ...process.env, OLLAMA_HOST: ollamaHost },
      encoding: 'utf8',
      timeout: 3000,
    });

  const ps = run(['ps']);
  if (ps.error && ps.error.code === 'ENOENT') return;
  if (ps.status !== 0) {
    console.error(`claude-proxy: cannot reach Ollama on ${ollamaHost} — is 'ollama serve' running? Skipping warm-up.`);
    return;
  }
  const loaded = ps.stdout.split('\n').slice(1).map(l => l.trim().split(/\s+/)[0]).filter(Boolean);
  if (loaded.includes(model)) return;
  const list = run(['list']);
  if (list.status !== 0) return;
  const cached = list.stdout.split('\n').slice(1).map(l => l.trim().split(/\s+/)[0]).filter(Boolean);
  if (!cached.includes(model)) {
    console.error(`claude-proxy: '${model}' not cached on ${ollamaHost} — run OLLAMA_HOST=${ollamaHost} ollama pull ${model} first`);
    return;
  }
  const numCtx = (CONFIG.ollama_defaults && CONFIG.ollama_defaults.num_ctx) || 65536;
  console.error(`claude-proxy: warming '${model}' on ${ollamaHost} (background)...`);
  const child = spawn('ollama', ['run', model, '--options', `num_ctx=${numCtx}`], {
    env: { ...process.env, OLLAMA_HOST: ollamaHost },
    detached: true,
    stdio: 'ignore',
  });
  child.unref();
}

function resolveBackend(model) {
  if (model == null || typeof model !== 'string' || !model.trim()) {
    return { error: 'model is required', status: 400 };
  }

  const modelRoutes = CONFIG.model_routes || {};
  const routes = CONFIG.routes || {};
  const backends = CONFIG.backends || {};

  // 1. Follow route graph first
  const terminalModel = resolveRouteModel(model);

  // 2. Try exact match in model_routes
  if (modelRoutes[terminalModel] !== undefined) {
    const id = modelRoutes[terminalModel];
    const backend = backends[id];
    if (!backend) return { error: `backend '${id}' not defined for model '${terminalModel}'`, status: 500, extra: { terminal_model: terminalModel } };
    return { backend: { id, ...backend }, effectiveModel: terminalModel };
  }

  // 3. Try pattern match in model_routes
  const patternBackend = lookupPatternValue('model_routes', terminalModel);
  if (patternBackend) {
    const backend = backends[patternBackend];
    if (!backend) return { error: `backend '${patternBackend}' not defined for pattern-matched model '${terminalModel}'`, status: 500, extra: { terminal_model: terminalModel } };
    return { backend: { id: patternBackend, ...backend }, effectiveModel: terminalModel };
  }

  // 4. If model was routed but terminal not in model_routes, try original model
  if (terminalModel !== model && modelRoutes[model] !== undefined) {
    const id = modelRoutes[model];
    const backend = backends[id];
    if (!backend) return { error: `backend '${id}' not defined for model '${model}'`, status: 500 };
    return { backend: { id, ...backend }, effectiveModel: model };
  }

  // 5. Default: unknown claude-* → anthropic, everything else → ollama fallback
  if (/^claude-/i.test(terminalModel)) {
    // Find the anthropic backend
    const anthroEntry = Object.entries(backends).find(([, v]) => (v.kind || 'anthropic') === 'anthropic');
    if (anthroEntry) {
      const [id, backend] = anthroEntry;
      return { backend: { id, ...backend }, effectiveModel: terminalModel };
    }
  }

  // 6. Ollama fallback
  console.error(`claude-proxy: '${terminalModel}' not in model_routes — assuming local Ollama at ${DEFAULT_OLLAMA_URL}`);
  return {
    backend: { id: '__ollama_fallback__', kind: 'ollama', url: DEFAULT_OLLAMA_URL, _ollamaFallback: true },
    effectiveModel: terminalModel,
  };
}

// ── Helper functions ───────────────────────────────────────────────────

function send(res, code, obj) {
  const body = JSON.stringify(obj);
  res.writeHead(code, {
    'content-type': 'application/json',
    'content-length': Buffer.byteLength(body),
  });
  res.end(body);
}

function sseEvent(res, eventName, data) {
  res.write(`event: ${eventName}\ndata: ${JSON.stringify(data)}\n\n`);
}

function addAnnotationHeaders(res, effectiveModel, backend) {
  if (ANNOTATE_MODEL) {
    res.setHeader('x-claude-proxy-served-by', effectiveModel || '');
  }
}

// ── Anthropic passthrough ──────────────────────────────────────────────
// Forwards the request body verbatim; replaces x-api-key with the real
// backend key from env. Streams SSE through untouched via pipe().
function forwardAnthropic(req, res, body, backend, effectiveModel) {
  const targetUrl = new URL(backend.url);
  const authKey = backend.auth_env ? process.env[backend.auth_env] : '';

  const bodyStr = body ? JSON.stringify(body) : '';
  const headers = {
    ...(body ? { 'content-type': 'application/json', 'content-length': Buffer.byteLength(bodyStr) } : {}),
    'anthropic-version': req.headers['anthropic-version'] || '2023-06-01',
    'accept': req.headers['accept'] || 'application/json',
  };
  if (req.headers['anthropic-beta']) headers['anthropic-beta'] = req.headers['anthropic-beta'];
  if (authKey) headers['x-api-key'] = authKey;
  // Forward custom request headers (x-custom-*)
  for (const [k, v] of Object.entries(req.headers)) {
    if (k.startsWith('x-custom-') || k.startsWith('x-upstream-')) headers[k] = v;
  }

  const isHttps = targetUrl.protocol === 'https:';
  const lib = isHttps ? https : http;
  const options = {
    hostname: targetUrl.hostname,
    port: targetUrl.port || (isHttps ? 443 : 80),
    path: req.url,
    method: req.method,
    headers,
  };

  const up = lib.request(options, upRes => {
    const respHeaders = { ...upRes.headers };
    if (ANNOTATE_MODEL && effectiveModel) respHeaders['x-claude-proxy-served-by'] = effectiveModel;
    res.writeHead(upRes.statusCode, respHeaders);
    upRes.pipe(res);
  });
  up.on('error', e => {
    if (!res.headersSent) send(res, 502, { error: e.message });
    else res.end();
  });
  if (bodyStr) up.write(bodyStr);
  up.end();
}

// ── Ollama Anthropic-compatible passthrough ────────────────────────────
// When Ollama exposes /v1/messages (Anthropic-compatible), forward the
// request verbatim. This preserves all fields: temperature, top_p, tools,
// tool_result, structured content, etc.
function forwardOllamaPassthrough(req, res, body, backend, effectiveModel) {
  const targetUrl = new URL(backend.url);
  const authKey = backend.auth_env ? process.env[backend.auth_env] : null;

  // Replace model with the resolved terminal model
  const outBody = { ...body, model: effectiveModel || body.model };

  const bodyStr = JSON.stringify(outBody);
  const headers = {
    'content-type': 'application/json',
    'content-length': Buffer.byteLength(bodyStr),
  };
  if (authKey) headers['authorization'] = `Bearer ${authKey}`;
  // Forward client API key if no auth_env
  if (!authKey && req.headers['x-api-key']) {
    headers['authorization'] = `Bearer ${req.headers['x-api-key']}`;
  }
  // Forward custom request headers (x-custom-*)
  for (const [k, v] of Object.entries(req.headers)) {
    if (k.startsWith('x-custom-') || k.startsWith('x-upstream-')) headers[k] = v;
  }

  const isHttps = targetUrl.protocol === 'https:';
  const lib = isHttps ? https : http;
  const options = {
    hostname: targetUrl.hostname,
    port: targetUrl.port || (isHttps ? 443 : 80),
    path: req.url,
    method: req.method,
    headers,
  };

  const up = lib.request(options, upRes => {
    const respHeaders = { ...upRes.headers };
    if (ANNOTATE_MODEL && effectiveModel) respHeaders['x-claude-proxy-served-by'] = effectiveModel;
    if (upRes.statusCode !== 200) {
      const errChunks = [];
      upRes.on('data', c => errChunks.push(c));
      upRes.on('end', () => {
        if (!res.headersSent) {
          res.writeHead(upRes.statusCode, respHeaders);
          res.end(Buffer.concat(errChunks));
        }
      });
      return;
    }
    // Stream SSE through
    res.writeHead(200, respHeaders);
    upRes.pipe(res);
  });
  up.on('error', e => {
    if (!res.headersSent) send(res, 502, { error: e.message });
    else res.end();
  });
  up.write(bodyStr);
  up.end();
}

// ── Ollama legacy translator (Phase 1, text-only) ──────────────────────
// Translates Anthropic /v1/messages → Ollama /api/chat request.
// Translates Ollama NDJSON response → Anthropic SSE response.
// Tool-use is not handled — tools blocks are silently dropped.
function forwardOllamaLegacy(req, res, body, backend, effectiveModel) {
  const targetUrl = new URL(backend.url);
  const authKey = backend.auth_env ? process.env[backend.auth_env] : null;

  const ollamaMessages = [];

  // System prompt: flatten content array or plain string
  if (body.system) {
    const systemText = Array.isArray(body.system)
      ? body.system.map(b => (typeof b === 'string' ? b : b.text || '')).join('\n')
      : String(body.system);
    if (systemText) ollamaMessages.push({ role: 'system', content: systemText });
  }

  // Messages: extract text blocks only (tool_use/tool_result blocks dropped for Phase 1)
  for (const msg of body.messages || []) {
    let content = '';
    if (typeof msg.content === 'string') {
      content = msg.content;
    } else if (Array.isArray(msg.content)) {
      content = msg.content
        .filter(b => b.type === 'text')
        .map(b => b.text || '')
        .join('');
    }
    ollamaMessages.push({ role: msg.role, content });
  }

  const ollamaBody = {
    model: body.model,
    messages: ollamaMessages,
    stream: true,
    options: {},
  };
  if (body.max_tokens)                               ollamaBody.options.num_predict  = body.max_tokens;
  if (body.temperature != null)                      ollamaBody.options.temperature  = body.temperature;
  if (body.top_p != null)                            ollamaBody.options.top_p        = body.top_p;
  if (body.top_k != null)                            ollamaBody.options.top_k        = body.top_k;
  if (body.stop_sequences && body.stop_sequences.length)
                                                     ollamaBody.options.stop         = body.stop_sequences;

  const ollamaDefaults = CONFIG.ollama_defaults || {};
  if (ollamaDefaults.num_ctx) ollamaBody.options.num_ctx = ollamaDefaults.num_ctx;

  const ollamaBodyStr = JSON.stringify(ollamaBody);
  const headers = {
    'content-type': 'application/json',
    'content-length': Buffer.byteLength(ollamaBodyStr),
  };
  if (authKey) headers['authorization'] = `Bearer ${authKey}`;

  const isHttps = targetUrl.protocol === 'https:';
  const lib = isHttps ? https : http;
  const options = {
    hostname: targetUrl.hostname,
    port: targetUrl.port || (isHttps ? 443 : 80),
    path: '/api/chat',
    method: 'POST',
    headers,
  };

  const msgId = `msg_${crypto.randomBytes(12).toString('hex')}`;

  const up = lib.request(options, upRes => {
    if (upRes.statusCode !== 200) {
      const errChunks = [];
      upRes.on('data', c => errChunks.push(c));
      upRes.on('end', () => {
        const errMsg = Buffer.concat(errChunks).toString();
        if (!res.headersSent) {
          const errHeaders = { 'content-type': 'application/json' };
          if (ANNOTATE_MODEL && effectiveModel) errHeaders['x-claude-proxy-served-by'] = effectiveModel;
          res.writeHead(upRes.statusCode, errHeaders);
          res.end(errMsg);
        }
      });
      return;
    }

    const respHeaders = {
      'content-type': 'text/event-stream',
      'cache-control': 'no-cache',
      'transfer-encoding': 'chunked',
    };
    if (ANNOTATE_MODEL && effectiveModel) respHeaders['x-claude-proxy-served-by'] = effectiveModel;
    res.writeHead(200, respHeaders);

    sseEvent(res, 'message_start', {
      type: 'message_start',
      message: { id: msgId, type: 'message', role: 'assistant', content: [], model: body.model, usage: { input_tokens: 0, output_tokens: 0 } },
    });
    sseEvent(res, 'content_block_start', { type: 'content_block_start', index: 0, content_block: { type: 'text', text: '' } });

    let outputTokens = 0;
    let buf = '';

    upRes.on('data', chunk => {
      buf += chunk.toString();
      const lines = buf.split('\n');
      buf = lines.pop();
      for (const line of lines) {
        const trimmed = line.trim();
        if (!trimmed) continue;
        let parsed;
        try { parsed = JSON.parse(trimmed); } catch { continue; }
        const text = parsed.message && parsed.message.content;
        if (text) {
          sseEvent(res, 'content_block_delta', { type: 'content_block_delta', index: 0, delta: { type: 'text_delta', text } });
        }
        if (parsed.done) outputTokens = parsed.eval_count || 0;
      }
    });

    upRes.on('end', () => {
      if (buf.trim()) {
        try {
          const parsed = JSON.parse(buf.trim());
          if (parsed.done && parsed.eval_count) outputTokens = parsed.eval_count;
        } catch { /* ignore */ }
      }
      sseEvent(res, 'content_block_stop', { type: 'content_block_stop', index: 0 });
      sseEvent(res, 'message_delta', { type: 'message_delta', delta: { stop_reason: 'end_turn', stop_sequence: null }, usage: { output_tokens: outputTokens } });
      sseEvent(res, 'message_stop', { type: 'message_stop' });
      res.end();
    });

    upRes.on('error', e => {
      console.error('claude-proxy: ollama upstream error:', e.message);
      res.end();
    });
  });

  up.on('error', e => {
    if (!res.headersSent) send(res, 502, { error: e.message });
    else res.end();
  });
  up.write(ollamaBodyStr);
  up.end();
}

function forwardOllama(req, res, body, backend, effectiveModel) {
  if (OLLAMA_LEGACY) {
    return forwardOllamaLegacy(req, res, body, backend, effectiveModel);
  }
  return forwardOllamaPassthrough(req, res, body, backend, effectiveModel);
}

// ── Request handler ───────────────────────────────────────────────────

async function readBody(req) {
  const chunks = [];
  for await (const c of req) chunks.push(c);
  return Buffer.concat(chunks);
}

function handleRequestWithFallback(req, res, body, resolved) {
  const { backend, effectiveModel } = resolved;
  const clientModel = body.model;

  const doForward = (b, em, fwdBody) => {
    if (b._ollamaFallback) ensureOllamaModelLoaded(em || clientModel, b.url);
    if (b.kind === 'anthropic') return forwardAnthropic(req, res, fwdBody, b, em);
    if (b.kind === 'ollama') return forwardOllama(req, res, fwdBody, b, em);
    return send(res, 500, { error: `unknown backend kind: ${b.kind}` });
  };

  if (!backend) return send(res, 500, { error: 'no backend resolved' });

  // Check if this model has fallback strategies
  const terminalModel = effectiveModel || clientModel;
  const strategies = CONFIG.fallback_strategies || {};
  const strategy = strategies[terminalModel];

  if (!strategy) {
    return doForward(backend, effectiveModel, body);
  }

  // Try primary — intercept the response to check for classified errors
  const targetUrl = new URL(backend.url);
  const authKey = backend.auth_env ? process.env[backend.auth_env] : '';
  const bodyStr = JSON.stringify(body);
  const fwdHeaders = {
    'content-type': 'application/json',
    'content-length': Buffer.byteLength(bodyStr),
    'anthropic-version': req.headers['anthropic-version'] || '2023-06-01',
    'accept': req.headers['accept'] || 'application/json',
  };
  if (req.headers['anthropic-beta']) fwdHeaders['anthropic-beta'] = req.headers['anthropic-beta'];
  if (authKey) fwdHeaders['x-api-key'] = authKey;
  for (const [k, v] of Object.entries(req.headers)) {
    if (k.startsWith('x-custom-') || k.startsWith('x-upstream-')) fwdHeaders[k] = v;
  }

  const isHttps = targetUrl.protocol === 'https:';
  const lib = isHttps ? https : http;

  const up = lib.request({
    hostname: targetUrl.hostname,
    port: targetUrl.port || (isHttps ? 443 : 80),
    path: req.url,
    method: req.method,
    headers: fwdHeaders,
  }, (upRes) => {
    const failureClass = classifyError(upRes.statusCode, upRes.headers);
    if (failureClass) {
      const fallbackModel = resolveFallbackModel(terminalModel, failureClass);
      if (fallbackModel) {
        setCooldown(terminalModel, failureClass, upRes.statusCode, upRes.headers);
        // Drain the error response
        upRes.resume();
        const fallbackResolved = resolveBackend(fallbackModel);
        if (!fallbackResolved.error) {
          const fwdBody = { ...body, model: fallbackModel };
          // For fallback, annotate with quota-fallback marker if account_quota
          if (failureClass === 'account_quota') {
            res.setHeader('x-claude-proxy-fallback-reason', 'quota-fallback');
          }
          return doForward(fallbackResolved.backend, fallbackResolved.effectiveModel, fwdBody);
        }
      }
    }
    // No fallback or not a classified error — forward the response as-is
    const respHeaders = { ...upRes.headers };
    if (ANNOTATE_MODEL && effectiveModel) respHeaders['x-claude-proxy-served-by'] = effectiveModel;
    res.writeHead(upRes.statusCode, respHeaders);
    upRes.pipe(res);
  });

  up.on('error', e => {
    const failureClass = 'network';
    const fallbackModel = resolveFallbackModel(terminalModel, failureClass);
    if (fallbackModel) {
      const fwdBody = { ...body, model: fallbackModel };
      const fallbackResolved = resolveBackend(fallbackModel);
      if (!fallbackResolved.error) {
        return doForward(fallbackResolved.backend, fallbackResolved.effectiveModel, fwdBody);
      }
    }
    if (!res.headersSent) send(res, 502, { error: { type: 'api_error', message: e.message } });
    else res.end();
  });

  up.write(bodyStr);
  up.end();
}

const server = http.createServer(async (req, res) => {
  // ── /ping ──────────────────────────────────────────────────────────
  if (req.url === '/ping') {
    return send(res, 200, {
      ok: true,
      pid: process.pid,
      config_path: CONFIG_PATH,
      config_source: CONFIG_SOURCE,
    });
  }

  // ── /debug/stats ────────────────────────────────────────────────────
  if (req.url === '/debug/stats') {
    return send(res, 200, {
      ...stats,
      currentInFlight: stats.currentInFlight,
    });
  }

  // ── /v1/models ──────────────────────────────────────────────────────
  if (req.method === 'GET' && req.url.startsWith('/v1/models')) {
    // Merge upstream Anthropic models with model_routes and routes keys
    const modelRoutes = CONFIG.model_routes || {};
    const routes = CONFIG.routes || {};
    const backends = CONFIG.backends || {};

    // Find the anthropic backend to proxy the upstream models list
    const anthroEntry = Object.entries(backends).find(([, v]) => (v.kind || 'anthropic') === 'anthropic');

    const localModels = [
      ...Object.keys(modelRoutes).map(id => ({
        id: id,
        type: 'model',
        display_name: id,
        capabilities: { thinking: { supported: true, types: {} } },
      })),
      ...Object.keys(routes).map(id => ({
        id: id,
        type: 'model',
        display_name: id,
        capabilities: { thinking: { supported: true, types: {} } },
      })),
    ];

    if (anthroEntry) {
      const [, anthroBackend] = anthroEntry;
      const authKey = anthroBackend.auth_env ? process.env[anthroBackend.auth_env] : '';
      const targetUrl = new URL(anthroBackend.url);
      const isHttps = targetUrl.protocol === 'https:';
      const lib = isHttps ? https : http;
      const upReq = lib.request({
        hostname: targetUrl.hostname,
        port: targetUrl.port || (isHttps ? 443 : 80),
        path: req.url,
        method: 'GET',
        headers: {
          ...(authKey ? { 'x-api-key': authKey } : {}),
          'anthropic-version': req.headers['anthropic-version'] || '2023-06-01',
        },
      }, (upRes) => {
        const chunks = [];
        upRes.on('data', c => chunks.push(c));
        upRes.on('end', () => {
          try {
            const upstream = JSON.parse(Buffer.concat(chunks).toString());
            const merged = [...(upstream.data || []), ...localModels];
            // Deduplicate by id
            const seen = new Set();
            const deduped = merged.filter(m => {
              if (seen.has(m.id)) return false;
              seen.add(m.id);
              return true;
            });
            return send(res, 200, { data: deduped, has_more: false, first_id: deduped[0]?.id, last_id: deduped[deduped.length - 1]?.id });
          } catch {
            return send(res, 200, { data: localModels, has_more: false });
          }
        });
      });
      upReq.on('error', () => {
        return send(res, 200, { data: localModels, has_more: false });
      });
      upReq.end();
      return;
    }

    return send(res, 200, { data: localModels, has_more: false });
  }

  // ── /v1/* passthrough ───────────────────────────────────────────────
  if (!req.url.startsWith('/v1/')) {
    return send(res, 404, { error: `unknown path: ${req.url}` });
  }

  // Non-POST /v1/* (e.g., GET /v1/me, GET /v1/models) — forward to Anthropic backend
  // GET /v1/models is handled above, so this is only other GET requests
  if (req.method !== 'POST') {
    const anthroEntry = Object.entries(CONFIG.backends || {}).find(([, v]) => (v.kind || 'anthropic') === 'anthropic');
    if (anthroEntry) {
      const [, anthroBackend] = anthroEntry;
      return forwardAnthropic(req, res, null, anthroBackend, null);
    }
    return send(res, 404, { error: 'no anthropic backend configured for non-POST requests' });
  }

  // Read request body for POST requests
  let body;
  try {
    const buf = await readBody(req);
    try {
      body = JSON.parse(buf.toString());
    } catch {
      return send(res, 400, { error: 'invalid json' });
    }
  } catch {
    return send(res, 400, { error: 'failed to read request body' });
  }

  // POST /v1/messages/count_tokens and other model-scoped endpoints
  if (req.url !== '/v1/messages') {
    // Model-scoped JSON endpoints: route by model field
    const model = body.model;
    if (model) {
      const resolved = resolveBackend(model);
      if (resolved.error) {
        const code = resolved.status || 400;
        const payload = { error: resolved.error };
        if (resolved.extra) Object.assign(payload, resolved.extra);
        return send(res, code, payload);
      }
      const { backend, effectiveModel } = resolved;
      const fwdBody = { ...body, model: effectiveModel || model };
      if (backend.kind === 'ollama') {
        // For Ollama: forward to Ollama's /v1/messages/count_tokens equivalent
        return forwardOllamaPassthrough(req, res, fwdBody, backend, effectiveModel);
      }
      return forwardAnthropic(req, res, fwdBody, backend, effectiveModel);
    }
  }

  // POST /v1/messages — main path
  const model = body.model;
  if (!model) {
    return send(res, 400, { error: 'model is required' });
  }

  const resolved = resolveBackend(model);
  if (resolved.error) {
    const code = resolved.status || 400;
    const payload = { error: resolved.error };
    if (resolved.extra) Object.assign(payload, resolved.extra);
    return send(res, code, payload);
  }

  stats.currentInFlight++;
  const { backend, effectiveModel } = resolved;
  const clientModel = model;

  // Patch model field with resolved model
  const fwdBody = { ...body, model: effectiveModel || model };

  // Track status via response wrapper
  const originalWriteHead = res.writeHead.bind(res);
  res.writeHead = function(statusCode, ...args) {
    recordStats(req.url, backend, clientModel, effectiveModel, statusCode);
    stats.currentInFlight = Math.max(0, stats.currentInFlight - 1);
    return originalWriteHead(statusCode, ...args);
  };

  // Use fallback-aware forwarding for models with strategies
  const terminalModel = effectiveModel || model;
  const strategies = CONFIG.fallback_strategies || {};
  if (strategies[terminalModel]) {
    handleRequestWithFallback(req, res, fwdBody, resolved);
  } else {
    if (backend._ollamaFallback) ensureOllamaModelLoaded(effectiveModel || model, backend.url);
    if (backend.kind === 'anthropic') return forwardAnthropic(req, res, fwdBody, backend, effectiveModel);
    if (backend.kind === 'ollama') return forwardOllama(req, res, fwdBody, backend, effectiveModel);
    return send(res, 500, { error: `unknown backend kind: ${backend.kind}` });
  }

});

server.listen(INITIAL_PORT, '127.0.0.1', () => {
  console.error(`claude-proxy listening on 127.0.0.1:${INITIAL_PORT} (pid=${process.pid})`);
});

process.on('SIGTERM', () => server.close(() => process.exit(0)));
process.on('SIGINT',  () => server.close(() => process.exit(0)));