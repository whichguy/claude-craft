#!/usr/bin/env node
'use strict';

const http = require('http');
const https = require('https');
const fs = require('fs');
const path = require('path');
const crypto = require('crypto');

const CONFIG_PATH = path.join(process.env.HOME, '.claude', 'model-map.json');
const PORT = Number(process.env.CLAUDE_PROXY_PORT) || 9999;

let CONFIG;
try {
  CONFIG = JSON.parse(fs.readFileSync(CONFIG_PATH, 'utf8'));
} catch (e) {
  console.error(`claude-proxy: failed to load ${CONFIG_PATH}: ${e.message}`);
  process.exit(1);
}

function resolveBackend(model) {
  const id = CONFIG.model_routes && CONFIG.model_routes[model];
  if (!id) return null;
  const backend = CONFIG.backends && CONFIG.backends[id];
  if (!backend) return null;
  return { id, ...backend };
}

function send(res, code, obj) {
  const body = JSON.stringify(obj);
  res.writeHead(code, {
    'content-type': 'application/json',
    'content-length': Buffer.byteLength(body),
  });
  res.end(body);
}

function sseEvent(res, eventName, data) {
  res.write(`event: ${eventName}\ndata: ${JSON.stringify(data)}\n\n`);
}

// ── Anthropic passthrough ─────────────────────────────────────────────
// Forwards the request body verbatim; replaces x-api-key with the real
// backend key from env. Streams SSE through untouched via pipe().
function forwardAnthropic(req, res, body, backend) {
  const targetUrl = new URL(backend.url);
  const authKey = backend.auth_env ? process.env[backend.auth_env] : '';

  const bodyStr = JSON.stringify(body);
  const headers = {
    'content-type': 'application/json',
    'content-length': Buffer.byteLength(bodyStr),
    'anthropic-version': req.headers['anthropic-version'] || '2023-06-01',
    'accept': req.headers['accept'] || 'application/json',
  };
  if (req.headers['anthropic-beta']) {
    headers['anthropic-beta'] = req.headers['anthropic-beta'];
  }
  // Replace the placeholder key from the shim with the real backend key
  if (authKey) headers['x-api-key'] = authKey;

  const isHttps = targetUrl.protocol === 'https:';
  const lib = isHttps ? https : http;
  const options = {
    hostname: targetUrl.hostname,
    port: targetUrl.port || (isHttps ? 443 : 80),
    path: req.url,
    method: req.method,
    headers,
  };

  const up = lib.request(options, upRes => {
    res.writeHead(upRes.statusCode, upRes.headers);
    upRes.pipe(res);
  });
  up.on('error', e => {
    if (!res.headersSent) send(res, 502, { error: e.message });
    else res.end();
  });
  up.write(bodyStr);
  up.end();
}

// ── Ollama text translator (Phase 1, text-only) ───────────────────────
// Translates Anthropic /v1/messages → Ollama /api/chat request.
// Translates Ollama NDJSON response → Anthropic SSE response.
// Tool-use (Phase 2) is not yet handled — tools blocks are silently dropped.
function forwardOllama(req, res, body, backend) {
  const targetUrl = new URL(backend.url);
  const authKey = backend.auth_env ? process.env[backend.auth_env] : null;

  // ── Request translation ───────────────────────────────────────────
  const ollamaMessages = [];

  // System prompt: flatten content array or plain string
  if (body.system) {
    const systemText = Array.isArray(body.system)
      ? body.system
          .map(b => (typeof b === 'string' ? b : b.text || ''))
          .join('\n')
      : String(body.system);
    if (systemText) ollamaMessages.push({ role: 'system', content: systemText });
  }

  // Messages: extract text blocks only (tool_use/tool_result blocks dropped for Phase 1)
  for (const msg of body.messages || []) {
    let content = '';
    if (typeof msg.content === 'string') {
      content = msg.content;
    } else if (Array.isArray(msg.content)) {
      content = msg.content
        .filter(b => b.type === 'text')
        .map(b => b.text || '')
        .join('');
    }
    ollamaMessages.push({ role: msg.role, content });
  }

  const ollamaBody = {
    model: body.model,
    messages: ollamaMessages,
    stream: true,    // always stream from Ollama; we translate to SSE
    options: {},
  };
  if (body.max_tokens) ollamaBody.options.num_predict = body.max_tokens;

  const ollamaBodyStr = JSON.stringify(ollamaBody);
  const headers = {
    'content-type': 'application/json',
    'content-length': Buffer.byteLength(ollamaBodyStr),
  };
  if (authKey) headers['authorization'] = `Bearer ${authKey}`;

  const isHttps = targetUrl.protocol === 'https:';
  const lib = isHttps ? https : http;
  const options = {
    hostname: targetUrl.hostname,
    port: targetUrl.port || (isHttps ? 443 : 80),
    path: '/api/chat',
    method: 'POST',
    headers,
  };

  const msgId = `msg_${crypto.randomBytes(12).toString('hex')}`;

  const up = lib.request(options, upRes => {
    if (upRes.statusCode !== 200) {
      const errChunks = [];
      upRes.on('data', c => errChunks.push(c));
      upRes.on('end', () => {
        const errMsg = Buffer.concat(errChunks).toString();
        if (!res.headersSent) {
          send(res, upRes.statusCode, { error: { type: 'api_error', message: errMsg } });
        }
      });
      return;
    }

    // ── Response translation ──────────────────────────────────────
    res.writeHead(200, {
      'content-type': 'text/event-stream',
      'cache-control': 'no-cache',
      'transfer-encoding': 'chunked',
    });

    sseEvent(res, 'message_start', {
      type: 'message_start',
      message: {
        id: msgId,
        type: 'message',
        role: 'assistant',
        content: [],
        model: body.model,
        usage: { input_tokens: 0, output_tokens: 0 },
      },
    });

    sseEvent(res, 'content_block_start', {
      type: 'content_block_start',
      index: 0,
      content_block: { type: 'text', text: '' },
    });

    let outputTokens = 0;
    let buf = '';

    upRes.on('data', chunk => {
      buf += chunk.toString();
      const lines = buf.split('\n');
      buf = lines.pop(); // retain incomplete trailing line

      for (const line of lines) {
        const trimmed = line.trim();
        if (!trimmed) continue;
        let parsed;
        try { parsed = JSON.parse(trimmed); } catch { continue; }

        const text = parsed.message && parsed.message.content;
        if (text) {
          sseEvent(res, 'content_block_delta', {
            type: 'content_block_delta',
            index: 0,
            delta: { type: 'text_delta', text },
          });
        }

        if (parsed.done) {
          outputTokens = parsed.eval_count || 0;
        }
      }
    });

    upRes.on('end', () => {
      // Flush any remaining buffer
      if (buf.trim()) {
        try {
          const parsed = JSON.parse(buf.trim());
          if (parsed.done && parsed.eval_count) outputTokens = parsed.eval_count;
        } catch { /* ignore malformed trailing data */ }
      }

      sseEvent(res, 'content_block_stop', { type: 'content_block_stop', index: 0 });
      sseEvent(res, 'message_delta', {
        type: 'message_delta',
        delta: { stop_reason: 'end_turn', stop_sequence: null },
        usage: { output_tokens: outputTokens },
      });
      sseEvent(res, 'message_stop', { type: 'message_stop' });
      res.end();
    });

    upRes.on('error', e => {
      console.error('claude-proxy: ollama upstream error:', e.message);
      res.end();
    });
  });

  up.on('error', e => {
    if (!res.headersSent) send(res, 502, { error: e.message });
    else res.end();
  });
  up.write(ollamaBodyStr);
  up.end();
}

// ── Server ────────────────────────────────────────────────────────────
const server = http.createServer(async (req, res) => {
  if (req.url === '/ping') {
    return send(res, 200, { ok: true, pid: process.pid });
  }

  if (!req.url.startsWith('/v1/')) {
    return send(res, 404, { error: `unknown path: ${req.url}` });
  }

  const chunks = [];
  try {
    for await (const c of req) chunks.push(c);
  } catch {
    return send(res, 400, { error: 'failed to read request body' });
  }

  let body;
  try {
    body = JSON.parse(Buffer.concat(chunks).toString());
  } catch {
    return send(res, 400, { error: 'invalid json' });
  }

  const backend = resolveBackend(body.model);
  if (!backend) {
    return send(res, 400, {
      error: `unknown model: ${body.model}`,
      available: Object.keys(CONFIG.model_routes || {}),
    });
  }

  if (backend.kind === 'anthropic') return forwardAnthropic(req, res, body, backend);
  if (backend.kind === 'ollama')    return forwardOllama(req, res, body, backend);
  return send(res, 500, { error: `unknown backend kind: ${backend.kind}` });
});

server.listen(PORT, '127.0.0.1', () => {
  console.error(`claude-proxy listening on 127.0.0.1:${PORT} (pid=${process.pid})`);
});

process.on('SIGTERM', () => server.close(() => process.exit(0)));
process.on('SIGINT',  () => server.close(() => process.exit(0)));
