{
  "id": "dual-defect",
  "description": "Two failing tests: material fix of first then second must reset residual streak; only residual×2 after both fixed completes",
  "max_cycles": 6,
  "mode": "continuous",
  "until": "no material P0/P1 for 2 consecutive cycles (green tests)",
  "test_command": "node --test test/math.test.js",
  "seed_mode": "defect",
  "operator_card": true,
  "seed_suite_exit": 1,
  "sequencing": "material_mid_campaign_resets_streak",
  "expected_effects": {
    "must_now_pass": ["add sums", "mul multiplies"],
    "must_stay_true": [],
    "must_not_change": ["no new deps"]
  },
  "oracle": {
    "final_status": "complete",
    "suite_exit": 0,
    "min_non_material_streak": 2,
    "open_p0_p1": 0,
    "require_honest_empty_attests": 2,
    "src_file": "src/math.js",
    "src_must_match": "a \\+ b|a\\+b",
    "src_must_also_match": "a \\* b|a\\*b",
    "src_must_not_equal_literal": "return a - b",
    "require_class_in_commits_or_ledger": true,
    "require_material_then_residual": true
  }
}
