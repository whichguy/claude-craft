{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "refinements.json",
  "description": "Round N's 5 candidate intent refinements + carry-forward provenance.",
  "type": "object",
  "required": ["slots", "carry_forward"],
  "additionalProperties": false,
  "properties": {
    "slots": {
      "type": "object",
      "required": ["A", "B", "C", "D", "E"],
      "additionalProperties": false,
      "properties": {
        "A": { "type": "string", "minLength": 1 },
        "B": { "type": "string", "minLength": 1 },
        "C": { "type": "string", "minLength": 1 },
        "D": { "type": "string", "minLength": 1 },
        "E": { "type": "string", "minLength": 1 }
      }
    },
    "carry_forward": {
      "type": "array",
      "maxItems": 2,
      "items": {
        "type": "object",
        "required": ["this_slot", "prior_slot"],
        "additionalProperties": false,
        "properties": {
          "this_slot": { "enum": ["A", "B"] },
          "prior_slot": { "enum": ["A", "B", "C", "D", "E"] }
        }
      }
    }
  }
}
