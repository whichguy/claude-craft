{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "stop-check.json",
  "description": "Stop-rule verdict for the current round.",
  "type": "object",
  "required": ["p_top", "p_second", "margin", "top_was_carried_forward", "winning_slot", "passes"],
  "additionalProperties": false,
  "properties": {
    "p_top": { "type": "number", "minimum": 0, "maximum": 1 },
    "p_second": { "type": "number", "minimum": 0, "maximum": 1 },
    "margin": { "type": "number" },
    "top_was_carried_forward": { "type": "boolean" },
    "winning_slot": { "enum": ["A", "B", "C", "D", "E"] },
    "passes": { "type": "boolean" }
  }
}
