{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "info-gain.json",
  "description": "Per-question expected entropy reduction, sorted descending.",
  "type": "array",
  "items": {
    "type": "object",
    "required": ["q_idx", "expected_reduction"],
    "additionalProperties": false,
    "properties": {
      "q_idx": { "type": "integer", "minimum": 0 },
      "expected_reduction": { "type": "number" }
    }
  }
}
