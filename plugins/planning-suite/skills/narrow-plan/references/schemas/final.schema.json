{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "final.json",
  "description": "Run summary written by the epilogue.",
  "type": "object",
  "required": ["verdict", "winning_slot", "winning_refinement", "final_distribution", "rounds_used", "run_dir", "synthesized_plan_path"],
  "additionalProperties": false,
  "properties": {
    "verdict": { "enum": ["converged", "did_not_converge"] },
    "winning_slot": { "enum": ["A", "B", "C", "D", "E"] },
    "winning_refinement": { "type": "string", "minLength": 1 },
    "final_distribution": { "$ref": "./distribution.schema.json" },
    "rounds_used": { "type": "integer", "minimum": 1 },
    "run_dir": { "type": "string", "minLength": 1 },
    "synthesized_plan_path": { "type": "string", "minLength": 1 },
    "reason": { "enum": ["cap_reached", "stagnation", "schema_failures_exceeded"] }
  }
}
