{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "tombstone record",
  "description": "One line of tombstones.jsonl. One Q/A captured per record.",
  "type": "object",
  "required": ["round", "question", "answer", "source", "agreed_by_two_framings"],
  "additionalProperties": false,
  "properties": {
    "round": { "type": "integer", "minimum": 1 },
    "question": { "type": "string", "minLength": 1 },
    "answer": { "type": "string", "minLength": 1 },
    "source": { "enum": ["llm", "user"] },
    "agreed_by_two_framings": { "type": "boolean" }
  }
}
