{
  "description": "Wiki: cache-first lifecycle — detect+inject, clear+boundary, notify+match, worker+extract, guard, cleanup+janitor, cache-rebuild, precompact, stop+serialize, session-end+safety-net. SessionStart 'clear' matcher fires when /clear creates a new session (Claude Code passes creation reason as matcher input).",
  "hooks": {
    "SessionStart": [{
      "matcher": "clear",
      "hooks": [{ "type": "command", "command": "${CLAUDE_PLUGIN_ROOT}/handlers/wiki-clear.sh", "timeout": 30, "async": true }]
    }, {
      "matcher": "*",
      "hooks": [
        { "type": "command", "command": "${CLAUDE_PLUGIN_ROOT}/handlers/wiki-detect.sh", "timeout": 10 },
        { "type": "command", "command": "${CLAUDE_PLUGIN_ROOT}/handlers/wiki-cleanup.sh", "timeout": 120, "async": true },
        { "type": "command", "command": "${CLAUDE_PLUGIN_ROOT}/handlers/wiki-cache-rebuild.sh", "timeout": 60, "async": true },
        { "type": "command", "command": "${CLAUDE_PLUGIN_ROOT}/handlers/wiki-worker.sh", "timeout": 900, "async": true }
      ]
    }],
    "UserPromptSubmit": [{
      "matcher": "*",
      "hooks": [
        { "type": "command", "command": "${CLAUDE_PLUGIN_ROOT}/handlers/wiki-notify.sh", "timeout": 5 },
        { "type": "command", "command": "${CLAUDE_PLUGIN_ROOT}/handlers/wiki-worker.sh", "timeout": 900, "async": true },
        { "type": "command", "command": "${CLAUDE_PLUGIN_ROOT}/handlers/wiki-periodic-extract.sh", "timeout": 10, "async": true }
      ]
    }],
    "PostToolUse": [{
      "matcher": "Write|Edit",
      "hooks": [
        { "type": "command", "command": "${CLAUDE_PLUGIN_ROOT}/handlers/wiki-cache-rebuild.sh", "timeout": 30, "async": true }
      ]
    }],
    "PreToolUse": [{
      "matcher": "Write|Edit",
      "hooks": [{ "type": "command", "command": "${CLAUDE_PLUGIN_ROOT}/handlers/wiki-raw-guard.sh", "timeout": 2 }]
    }],
    "PreCompact": [{
      "matcher": "*",
      "hooks": [{ "type": "command", "command": "${CLAUDE_PLUGIN_ROOT}/handlers/wiki-precompact.sh", "timeout": 10 }]
    }],
    "Stop": [{
      "matcher": "*",
      "hooks": [{ "type": "command", "command": "${CLAUDE_PLUGIN_ROOT}/handlers/wiki-stop.sh", "timeout": 30, "async": true }]
    }],
    "SessionEnd": [{
      "matcher": "*",
      "hooks": [{ "type": "command", "command": "${CLAUDE_PLUGIN_ROOT}/handlers/wiki-session-end.sh", "timeout": 10 }]
    }]
  }
}
