{
  "description": "Wiki: 8-handler lifecycle — detect+mark, clear+boundary, notify+inject, process+queue, guard, precompact, stop+serialize, session-end+safety-net",
  "hooks": {
    "SessionStart": [{
      "matcher": "clear",
      "hooks": [{ "type": "command", "command": "${CLAUDE_PLUGIN_ROOT}/handlers/wiki-clear.sh", "timeout": 10, "async": true }]
    }, {
      "matcher": "*",
      "hooks": [
        { "type": "command", "command": "${CLAUDE_PLUGIN_ROOT}/handlers/wiki-detect.sh", "timeout": 5 },
        { "type": "command", "command": "${CLAUDE_PLUGIN_ROOT}/handlers/wiki-queue-nudge.sh", "timeout": 300, "async": true }
      ]
    }],
    "UserPromptSubmit": [{
      "matcher": "*",
      "hooks": [
        { "type": "command", "command": "${CLAUDE_PLUGIN_ROOT}/handlers/wiki-notify.sh", "timeout": 3 },
        { "type": "command", "command": "${CLAUDE_PLUGIN_ROOT}/handlers/wiki-queue-nudge.sh", "timeout": 300, "async": true }
      ]
    }],
    "PreToolUse": [{
      "matcher": "Write|Edit",
      "hooks": [{ "type": "command", "command": "${CLAUDE_PLUGIN_ROOT}/handlers/wiki-raw-guard.sh", "timeout": 2 }]
    }],
    "PreCompact": [{
      "matcher": "*",
      "hooks": [{ "type": "command", "command": "${CLAUDE_PLUGIN_ROOT}/handlers/wiki-precompact.sh", "timeout": 5 }]
    }],
    "Stop": [{
      "matcher": "*",
      "hooks": [{ "type": "command", "command": "${CLAUDE_PLUGIN_ROOT}/handlers/wiki-stop.sh", "timeout": 15, "async": true }]
    }],
    "SessionEnd": [{
      "matcher": "*",
      "hooks": [{ "type": "command", "command": "${CLAUDE_PLUGIN_ROOT}/handlers/wiki-session-end.sh", "timeout": 5 }]
    }]
  }
}
