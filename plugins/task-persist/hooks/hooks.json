{
  "hooks": {
    "SessionStart": [
      {
        "matcher": "clear",
        "hooks": [
          { "type": "command", "command": "${CLAUDE_PLUGIN_ROOT}/handlers/task-persist-restore.sh", "timeout": 5 }
        ]
      },
      {
        "matcher": "startup",
        "hooks": [
          { "type": "command", "command": "${CLAUDE_PLUGIN_ROOT}/handlers/task-persist-restore.sh", "timeout": 5 }
        ]
      }
    ]
  }
}
